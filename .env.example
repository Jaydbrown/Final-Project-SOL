# Copy to .env and fill with your own keys. Do not commit .env.

VITE_PRIVY_APP_ID=

# Optional signer / admin flows if your Privy setup requires them
VITE_PRIVY_SIGNER_ID=

VITE_CHAIN_ID=
VITE_CHAIN_NAME=
VITE_RPC_URL=
VITE_EXPLORER_URL=

VITE_FACTORY_ADDRESS=
VITE_USDC_ADDRESS=

# Frontend → backend API (defaults to http://localhost:3001 in code if unset)
VITE_BACKEND_URL=http://localhost:3001

# Pinata JWT for DAO logos, profile photos, and chat image uploads
VITE_PINATA_JWT=

# Optional
VITE_IPFS_UPLOAD_TIMEOUT_MS=

# Optional: DAO chat persistence + Realtime (use anon/publishable key only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Or: VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional: injected into the bundle by vite.config (if you enable Gemini-backed features)
# GEMINI_API_KEY=
