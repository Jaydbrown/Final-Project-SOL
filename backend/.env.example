DATABASE_URL=file:./prisma/dev.db
PORT=3001
FRONTEND_URL=http://localhost:3000

# Google OAuth (same client as “Connect Gmail” in the app)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3001/api/auth/gmail/callback

# Outbound mail for chat alerts (mailbox that actually sends email)
GMAIL_FROM_EMAIL=notifications@yourdomain.com
GMAIL_MAILER_REFRESH_TOKEN=

# Fallback if you prefer app passwords instead of GMAIL_MAILER_REFRESH_TOKEN:
# GMAIL_USER=notifications@yourdomain.com
# GMAIL_APP_PASSWORD=

# --- RabbitMQ (async workers + dead-letter queues) ---
# Local (docker compose -f docker-compose.rabbitmq.yml):
#   RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_URL=
# Heartbeat seconds (TCP keepalive for firewalls / load balancers)
RABBITMQ_HEARTBEAT=30
# Unacked jobs per consumer channel (tune with worker CPU + DB pool)
RABBIT_PREFETCH=32
# Max application-level requeue attempts before message → DLQ
RABBIT_MAX_JOB_ATTEMPTS=5
